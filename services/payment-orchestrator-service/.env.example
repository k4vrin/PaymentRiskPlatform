# Spring profile
SPRING_PROFILES_ACTIVE=local

# Server
SERVER_PORT=8080

# PostgreSQL / R2DBC
PAYMENT_RISK_R2DBC_URL=r2dbc:postgresql://localhost:5432/payment_risk
PAYMENT_RISK_FLYWAY_JDBC_URL=jdbc:postgresql://localhost:5432/payment_risk
PAYMENT_RISK_DB_USERNAME=payment_risk
PAYMENT_RISK_DB_PASSWORD=payment_risk

# Redis
PAYMENT_RISK_REDIS_HOST=localhost
PAYMENT_RISK_REDIS_PORT=6379

# Kafka
PAYMENT_RISK_KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# RabbitMQ
PAYMENT_RISK_RABBITMQ_HOST=localhost
PAYMENT_RISK_RABBITMQ_PORT=5672
PAYMENT_RISK_RABBITMQ_USERNAME=payment_risk
PAYMENT_RISK_RABBITMQ_PASSWORD=payment_risk

# Local Spring Security user
SPRING_SECURITY_USER_NAME=dev
SPRING_SECURITY_USER_PASSWORD=dev-pass
SPRING_SECURITY_USER_ROLES=ADMIN,MERCHANT,OPS,AUDITOR,SERVICE
